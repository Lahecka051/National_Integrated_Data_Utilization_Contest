# 공공데이터포털 API 인증키 (Decoding 키 권장)
DATA_GO_KR_API_KEY=your_api_key_here
# (선택) Encoding 키 — Decoding 키로 실패할 때 폴백용
DATA_GO_KR_API_KEY_ENCODING=

# 기상청 단기예보 API 인증키 (data.go.kr 동일 키 사용 가능)
WEATHER_API_KEY=your_api_key_here

# 카카오맵 JavaScript API 키
KAKAO_MAP_API_KEY=your_kakao_key_here

# 카카오 REST API 키 (Local/Navi)
KAKAO_REST_API_KEY=your_kakao_rest_key_here

# 서울 열린데이터광장 API 인증키 (공영주차장 실시간 잔여면수용)
SEOUL_OPENDATA_API_KEY=your_seoul_opendata_key_here

# Google Gemini API Key (무료: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 서버 설정
BACKEND_PORT=8000
FRONTEND_PORT=5173
